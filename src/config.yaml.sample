# AIGM Ecosystem 設定ファイル
# このファイルを編集することで各PHPファイルの設定を一元管理できます

ollama:
  api_url: 
  default_model: gemma4:e4b
  # モデル別設定
  models:
    fast: gemma4:e4b
    smart: gemma3:12b

site:
  base_url: 
  cookie_domain: 
  admin: 
  gtag_id: 

x_api:
  key_file: 

finreport:
  api_url:
  # 自動生成ワーカーのデフォルトは環境変数で調整します:
  # FINREPORT_WORKER_RUN_HOURS=9,21
  # FINREPORT_WORKER_MAX_ITEMS=2

polymarket:
  api_url:

rqdb4ai:
  api_base:
  api_token:

uslideblog:
  renderer_api: http://exbridge.ddns.net:8022

ustory:
  # ollama / oauth_claude / codex_cli
  ai_provider: oauth_claude
  openclaw_bin: /home/kojima/.nvm/versions/node/v24.16.0/bin/openclaw
  openclaw_model: claude-cli/claude-sonnet-4-6
  codex_model: gpt-5.5
  codex_bin:
  ai_timeout: 180

paragraph:
