# AIGM Ecosystem 設定ファイル
# このファイルを編集することで各PHPファイルの設定を一元管理できます

ollama:
  api_url: 
  default_model: gemma4:e4b
  # モデル別設定
  models:
    fast: gemma4:e4b
    smart: gemma3:12b

site:
  base_url: 
  cookie_domain: 
  admin: 
  gtag_id: 

x_api:
  key_file: 

finreport:
  api_url:
  # 自動生成ワーカーのデフォルトは環境変数で調整します:
  # FINREPORT_WORKER_RUN_HOURS=9,21
  # FINREPORT_WORKER_MAX_ITEMS=2

polymarket:
  api_url:

rqdb4ai:
  api_base:
  api_token:

uslideblog:
  renderer_api: http://exbridge.ddns.net:8022

ustory:
  # ollama / oauth_claude / codex_cli
  # oauth_claude is executed by the RQDB4AI worker as OAuth-authenticated Claude CLI.
  ai_provider: oauth_claude
  claude_model: sonnet
  claude_bin:
  codex_model: gpt-5.5
  codex_bin:
  ai_timeout: 180

paragraph:
  api_key: 
  publication_slug: 
