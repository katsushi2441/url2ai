[Unit]
Description=URL2AI OSS RQ Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=kojima
WorkingDirectory=/home/kojima/work/url2ai
ExecStart=/home/kojima/work/url2ai/scripts/run_url2ai_ollama_rq_worker.sh
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
StandardOutput=append:/home/kojima/url2ai_ollama_rq_worker.log
StandardError=append:/home/kojima/url2ai_ollama_rq_worker.log

[Install]
WantedBy=multi-user.target
