[Unit]
Description=OSS Worker - GitHub Trending Auto Register
After=network.target

[Service]
Type=simple
User=kojima
WorkingDirectory=/home/kojima/work/url2ai/src
ExecStart=/usr/bin/python3 /home/kojima/work/url2ai/src/oss_worker.py
Restart=always
RestartSec=10
Environment=PARAGRAPH_API_KEY=
StandardOutput=append:/home/kojima/oss_worker.log
StandardError=append:/home/kojima/oss_worker.log

[Install]
WantedBy=multi-user.target
