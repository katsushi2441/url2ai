[Unit]
Description=Kurage URL2AI Brain JPYC x402 Payment Gateway (DeepSeek + real publish)
After=network.target

[Service]
WorkingDirectory=/home/kojima/work/url2ai/apps/llm-gateway
ExecStart=/home/kojima/.local/node-v22.15.0/bin/node server-jpyc-url2brain.js
Restart=always
RestartSec=5
EnvironmentFile=-/home/kojima/work/url2ai/apps/llm-gateway/.env.jpyc
EnvironmentFile=-/home/kojima/work/url2brain/.env
Environment=PATH=/home/kojima/.local/node-v22.15.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=PORT_JPYC_URL2BRAIN=18333
Environment=URL2BRAIN_URL=http://127.0.0.1:18332

[Install]
WantedBy=multi-user.target
