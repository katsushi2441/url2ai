[Unit]
Description=Kurage Crypto Brain JPYC x402 Payment Gateway (DeepSeek V4 Flash)
After=network.target

[Service]
WorkingDirectory=/home/kojima/work/url2ai/apps/llm-gateway
ExecStart=/home/kojima/.local/node-v22.15.0/bin/node server-jpyc-kcbrain.js
Restart=always
RestartSec=5
EnvironmentFile=-/home/kojima/work/url2ai/apps/llm-gateway/.env.jpyc
EnvironmentFile=-/home/kojima/work/kcbrain/.env
Environment=PATH=/home/kojima/.local/node-v22.15.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=PORT_JPYC_KCBRAIN=18331
Environment=KCBRAIN_URL=http://127.0.0.1:18328

[Install]
WantedBy=multi-user.target
