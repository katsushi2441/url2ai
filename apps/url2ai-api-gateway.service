[Unit]
Description=URL2AI Unified FastAPI Gateway
After=network.target

[Service]
Type=simple
User=kojima
WorkingDirectory=/home/kojima/work/url2ai/apps
EnvironmentFile=/home/kojima/work/url2ai/apps/.env.api-gateway
ExecStart=/home/kojima/work/url2ai/apps/ernie-image-turbo/.venv-cu128/bin/uvicorn api_gateway:app --host ${HOST} --port ${PORT}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
